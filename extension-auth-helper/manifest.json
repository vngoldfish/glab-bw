{
   "action": {
      "default_icon": {
         "128": "icon128.png",
         "48": "icon48.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://labs.google/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "content_grok.js" ],
      "matches": [ "https://grok.com/*" ],
      "run_at": "document_idle"
   } ],
   "default_locale": "en",
   "description": "__MSG_appDescription__",
   "host_permissions": [ "https://labs.google/*", "https://grok.com/*", "https://*.grok.com/*", "http://localhost/*", "http://127.0.0.1/*", "*://*.google.com/*" ],
   "icons": {
      "128": "icon128.png",
      "48": "icon48.png"
   },
   "manifest_version": 3,
   "name": "__MSG_appName__",
   "options_ui": {
      "page": "options.html",
      "open_in_tab": false
   },
   "permissions": [ "alarms", "cookies", "tabs", "scripting", "storage", "webRequest" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "7.0.0",
   "web_accessible_resources": [ {
      "matches": [ "https://labs.google/*", "https://grok.com/*" ],
      "resources": [ "page_script.js", "icon48.png", "popup.html", "popup.js" ]
   } ]
}
