# ============================================================
#  G-Labs BW — Cấu hình môi trường
#  Copy file này → .env (cùng thư mục project)
#  File .env không được đưa lên Git (đã có trong .gitignore)
# ============================================================

# ─── Cơ bản ──────────────────────────────────────────────────
APP_NAME=G-Labs BW
HOST=127.0.0.1
PORT=8765
AUTH_BRIDGE_URL=http://127.0.0.1:18923

# API Key — để trống: tự sinh và lưu vào data/api_key.txt
# Một khi đã sinh sẽ ổn định qua các lần restart
API_KEY=

# ─── Hiệu suất ───────────────────────────────────────────────
# Nên để 3–5 để tránh bị Google Flow rate-limit / captcha
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_SECONDS=600
LOG_LEVEL=INFO

# ─── CORS (Cross-Origin Resource Sharing) ────────────────────
# Kiểm soát website nào được phép gọi API của bạn từ trình duyệt.
#
# CÀI LOCAL (mặc định — không cần đặt gì):
#   Khi để trống, server tự cho phép: localhost:5173, 127.0.0.1:8765
#   Điều này đủ dùng cho dev và production local.
#
# LÊN VPS — Chỉ cần làm 1 trong 3 cách sau:
#
# ── Cách 1 (KHUYÊN DÙNG): Chỉ đặt VPS_DOMAIN ────────────────
#   Server tự thêm https://domain.com, http://domain.com, https://www.domain.com
#   VPS_DOMAIN=myapp.example.com
VPS_DOMAIN=

# ── Cách 2: Liệt kê thủ công nhiều origin ────────────────────
#   Phân cách bằng dấu phẩy, không có khoảng trắng thừa
#   CORS_ORIGINS=https://myapp.example.com,https://admin.myapp.com
CORS_ORIGINS=

# ── Cách 3: Mở toàn bộ (KHÔNG DÙNG TRÊN INTERNET) ──────────
#   Chỉ dùng khi: VPS nội bộ, không expose ra internet, hoặc debug tạm thời
#   CORS_ALLOW_ALL=true
CORS_ALLOW_ALL=false