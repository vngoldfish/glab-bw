# Copy to .env in project root (optional — backend có giá trị mặc định)
APP_NAME=G-Labs BW
HOST=127.0.0.1
PORT=8765
AUTH_BRIDGE_URL=http://127.0.0.1:18923
# Để trống: auto generate + lưu data/api_key.txt (ổn định qua restart)
API_KEY=
# Nên 3–5 để tránh spam Google Flow / captcha
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_SECONDS=600
LOG_LEVEL=INFO